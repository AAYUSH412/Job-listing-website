{
    "version": 2,
    "builds": [
      {
        "src": "api/jobs.js",
        "use": "@vercel/node",
        "config": { "runtime": "edge" }
      },
      {
        "src": "package.json",
        "use": "@vercel/static-build",
        "config": { "distDir": "dist" }
      }
    ],
    "routes": [
      {
        "src": "/api/.*",
        "dest": "/api/jobs.js"
      },
      {
        "src": "/(.*)",
        "dest": "/index.html"
      }
    ]
  }